{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WaveLinux",
  "mainBinaryName": "wavelinux",
  "version": "4.3.6",
  "identifier": "io.github.duskyprojects.WaveLinux",
  "build": {
    "beforeDevCommand": "cd .. && node node_modules/.bin/vite --port 1420",
    "beforeBuildCommand": "cd .. && node node_modules/.bin/tsc && node node_modules/.bin/vite build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../dist"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "WaveLinux 4.3.6",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Linux creator audio mixer",
    "longDescription": "WaveLinux is a Rust and PipeWire creator audio mixer for Linux.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true,
        "files": {
          "/usr/lib": "appimage-extra/usr/lib",
          "/usr/wavelinux-runtime": "appimage-extra/usr/wavelinux-runtime"
        }
      },
      "deb": {
        "depends": [
          "pipewire",
          "wireplumber",
          "pipewire-pulse",
          "pipewire-bin",
          "pulseaudio-utils",
          "alsa-utils",
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "libusb-1.0-0",
          "bubblewrap",
          "xdg-dbus-proxy",
          "xwayland",
          "libegl1",
          "libgl1",
          "libgbm1",
          "libdrm2",
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good",
          "fonts-dejavu-core",
          "xdg-desktop-portal",
          "xdg-desktop-portal-gtk"
        ],
        "recommends": ["swh-plugins", "librnnoise-ladspa"]
      },
      "rpm": {
        "depends": [
          "pipewire",
          "wireplumber",
          "pipewire-pulseaudio",
          "pulseaudio-utils",
          "alsa-utils",
          "webkit2gtk4.1",
          "libappindicator-gtk3",
          "libusb1",
          "bubblewrap",
          "xdg-dbus-proxy",
          "xorg-x11-server-Xwayland",
          "mesa-libEGL",
          "mesa-libGL",
          "mesa-libgbm",
          "libdrm",
          "gstreamer1-plugins-base",
          "gstreamer1-plugins-good",
          "google-noto-sans-fonts",
          "xdg-desktop-portal",
          "xdg-desktop-portal-gtk"
        ],
        "recommends": ["ladspa-swh-plugins", "lsp-plugins-ladspa", "rnnoise"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2QjhFQjM3NzFDRkY2MwpSV1JqL3h4M3M0NXJCMXJDbm5GQ3F2ajdPdVRzanBIREJQYzdHL2FTVG44cFFTVm5XWlZQeVBqawo=",
      "endpoints": [
        "https://github.com/DuskyProjects/WaveLinux/releases/latest/download/latest.json"
      ]
    }
  }
}
