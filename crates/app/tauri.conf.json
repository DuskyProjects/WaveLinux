{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WaveLinux",
  "version": "4.0.0",
  "identifier": "io.github.duskyprojects.WaveLinux",
  "build": {
    "beforeDevCommand": "cd .. && node node_modules/.bin/vite --port 1420",
    "beforeBuildCommand": "cd .. && node node_modules/.bin/tsc && node node_modules/.bin/vite build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../dist"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "WaveLinux 4.0",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Linux creator audio mixer",
    "longDescription": "WaveLinux is a Rust and PipeWire creator audio mixer for Linux.",
    "linux": {
      "deb": {
        "depends": ["pipewire", "wireplumber", "pipewire-pulse", "libwebkit2gtk-4.1-0"]
      }
    }
  }
}
