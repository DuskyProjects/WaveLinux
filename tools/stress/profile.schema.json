{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wavelinux.local/tools/stress/profile.schema.json",
  "title": "WaveLinux Stress Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_name",
    "appimage_path",
    "bluetooth",
    "mics",
    "fallback_speaker"
  ],
  "properties": {
    "profile_name": {
      "type": "string",
      "minLength": 1
    },
    "appimage_path": {
      "type": "string",
      "minLength": 1
    },
    "bluetooth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mac",
        "card_name",
        "sink_name",
        "preferred_profile",
        "bad_profiles",
        "bad_source_name"
      ],
      "properties": {
        "mac": {
          "type": "string",
          "minLength": 1
        },
        "card_name": {
          "type": "string",
          "minLength": 1
        },
        "sink_name": {
          "type": "string",
          "minLength": 1
        },
        "preferred_profile": {
          "type": "string",
          "minLength": 1
        },
        "bad_profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "bad_source_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external",
        "internal"
      ],
      "properties": {
        "external": {
          "type": "string",
          "minLength": 1
        },
        "internal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fallback_speaker": {
      "type": "string",
      "minLength": 1
    }
  }
}
