{
  "name": "wavelinux",
  "version": "4.3.1",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "cd crates/app && ../../node_modules/.bin/tauri dev",
    "build": "tsc && vite build",
    "desktop:dev": "cd crates/app && ../../node_modules/.bin/tauri dev",
    "desktop:build": "bash scripts/build-local.sh",
    "desktop:release": "bash scripts/build-release.sh",
    "aur:build": "bash scripts/build-aur.sh",
    "deps:check": "bash scripts/check-dependencies.sh",
    "deps:install": "WAVELINUX_INSTALL_DEPS=1 WAVELINUX_INSTALL_EFFECTS=1 bash scripts/check-dependencies.sh",
    "effects:install": "WAVELINUX_INSTALL_EFFECTS=1 bash scripts/check-dependencies.sh",
    "install:local": "bash scripts/install-local.sh",
    "install:alsa-aliases": "bash scripts/install-alsa-aliases.sh",
    "uninstall:local": "bash scripts/uninstall-local.sh",
    "replace:local": "bash scripts/uninstall-local.sh && bash scripts/build-local.sh && bash scripts/install-local.sh",
    "release:key": "bash scripts/generate-release-key.sh",
    "release:sign": "bash scripts/sign-release-artifacts.sh",
    "profiles:assets": "bash scripts/build-hardware-profile-assets.sh",
    "test:all": "bash scripts/test-all.sh",
    "tauri:dev": "cd crates/app && ../../node_modules/.bin/tauri dev",
    "tauri:build": "bash scripts/build-local.sh",
    "web:dev": "vite --port 1420",
    "web:build": "tsc && vite build",
    "web:preview": "vite preview --port 1420"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
